rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'eGjKT3AHFKg1sJcFkJaroYoySJX2' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isBanned() {
      return exists(/databases/$(database)/documents/bannedUsers/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /bannedUsers/{uid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /politicianScores/{pid} {
      allow read: if true;
      allow write: if request.auth != null && !isBanned();
    }

    match /complaints/{cid} {
      allow read: if true;
      allow create: if request.auth != null && !isBanned()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.desc is string
        && request.resource.data.desc.size() >= 50;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /comments/{cid} {
      allow read: if true;
      allow create: if request.auth != null && !isBanned()
        && request.auth.token.email != null
        && request.auth.token.email is string
        && request.auth.token.email.size() > 0
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 3
        && request.resource.data.text.size() <= 500;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /loginLogs/{id} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /submissions/{sid} {
      allow create: if request.auth != null && !isBanned()
        && request.auth.token.email != null
        && request.resource.data.submittedBy == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.submittedBy == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /approvedPoliticians/{pid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /votes/{pid} {
        allow read, write: if request.auth != null && request.auth.uid == uid && !isBanned();
      }
    }
  }
}
