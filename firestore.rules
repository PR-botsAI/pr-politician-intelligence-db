rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Politician aggregate scores: public read, authed write
    match /politicianScores/{pid} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Complaints: public read, authed create, owner-only delete/update
    match /complaints/{cid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.desc is string
        && request.resource.data.desc.size() >= 50;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // User profile: public read (for future leaderboards), owner-only write
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;

      // User's votes subcollection: private to the user
      match /votes/{pid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
